# ═══════════════════════════════════════════════════════════════════════
# Move Like Buffett — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your API keys.
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════════════════


# ── LLM (DeepSeek) ───────────────────────────────────────────────────
# Powers the RAG chatbot. Get key: https://platform.deepseek.com
DEEPSEEK_API_KEY=your-deepseek-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat


# ── Twelve Data (stock fallback) ─────────────────────────────────────
# Free tier: 800 req/day, 8 req/min. Get key: https://twelvedata.com/register
# Used for quotes + price history when Yahoo Finance is rate-limited.
TD_API_KEY=your-twelvedata-key-here
TD_DAILY_BUDGET=800
TD_RESERVE_BUDGET=50


# ── Embedding Model ──────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2


# ── RAG Tuning ───────────────────────────────────────────────────────
QA_MATCH_THRESHOLD=0.82
RETRIEVAL_TOP_K=6
CHUNK_TOP_K=4


# ── Yahoo Finance: Rate Limiting ─────────────────────────────────────
YF_MAX_RETRIES=3
YF_COOLDOWN_SECONDS=2.0
YF_RETRY_BASE_SECONDS=15
YF_RATE_LIMIT_WAIT=75
YF_QUOTE_DELAY_MS=250


# ── Yahoo Finance: Cache TTLs (seconds) ──────────────────────────────
YF_TTL_QUOTES=600
YF_TTL_PRICE=21600
YF_TTL_FUNDAMENTALS=86400
YF_TTL_INFO=21600


# ── Data Paths (optional, defaults are fine) ─────────────────────────
# QA_CSV_DIR=data/csvs
# CHUNK_PKL_DIR=data/chunks
# FAISS_INDEX_DIR=data/indices


# ── Server ───────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info